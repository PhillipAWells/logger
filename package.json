{
	"name": "@pawells/logger",
	"displayName": "@pawells/logger",
	"version": "1.2.0",
	"description": "Structured logging library for TypeScript/Node.js with support for multiple transports and log aggregation",
	"type": "module",
	"main": "./build/index.js",
	"types": "./build/index.d.ts",
	"exports": {
		".": {
			"types": "./build/index.d.ts",
			"import": "./build/index.js"
		},
		"./testing/vitest": {
			"types": "./build/testing/vitest.d.ts",
			"import": "./build/testing/vitest.js"
		},
		"./testing/jest": {
			"types": "./build/testing/jest.d.ts",
			"import": "./build/testing/jest.js"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"start": "node build/index.js",
		"dev": "tsc && node build/index.js",
		"watch": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage",
		"pipeline": "yarn typecheck && yarn lint && yarn test && yarn build",
		"prepublishOnly": "yarn build",
		"prepare": "husky"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@jest/globals": "^30.3.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/node": "^25.4.0",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/ui": "^4.0.18",
		"eslint": "^10.0.3",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-unused-imports": "^4.0.0",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"typescript": "^5.3.3",
		"vitest": "^4.0.18"
	},
	"keywords": [
		"logger",
		"logging",
		"structured-logging",
		"typescript",
		"esm",
		"node",
		"transport",
		"aggregation"
	],
	"author": "Phillip Aaron Wells",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PhillipAWells/logger.git"
	},
	"bugs": {
		"url": "https://github.com/PhillipAWells/logger/issues"
	},
	"homepage": "https://github.com/PhillipAWells/logger#readme",
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "yarn@4.12.0",
	"files": [
		"build/",
		"README.md",
		"LICENSE"
	],
	"peerDependencies": {
		"@jest/globals": ">=27.0.0",
		"vitest": ">=1.0.0"
	},
	"peerDependenciesMeta": {
		"@jest/globals": {
			"optional": true
		},
		"vitest": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public"
	}
}